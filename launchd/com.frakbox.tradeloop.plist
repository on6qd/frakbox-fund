<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.frakbox.tradeloop</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/frakbox/Bots/frakbox_fund/venv/bin/python3</string>
        <string>/Users/frakbox/Bots/frakbox_fund/trade_loop.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/frakbox/Bots/frakbox_fund</string>

    <!-- Every 120s: stop-losses, triggers, reconciliation against the Turso replica.
         Secrets are NOT here — trade_loop reads .env via config.py / db.py. -->
    <key>StartInterval</key>
    <integer>120</integer>
    <key>RunAtLoad</key>
    <true/>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/Users/frakbox/Bots/frakbox_fund/venv/bin</string>
        <key>HOME</key>
        <string>/Users/frakbox</string>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/frakbox/Bots/frakbox_fund/logs/trade_loop.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/frakbox/Bots/frakbox_fund/logs/trade_loop_err.log</string>
</dict>
</plist>
